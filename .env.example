# Copy this file to .env and fill in values for your environment.
# .env is gitignored and should never be committed.

# Generate a new key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hostnames (no spaces)
# Example: ALLOWED_HOSTS=finance.yourdomain.com,192.168.1.100
ALLOWED_HOSTS=localhost,127.0.0.1
